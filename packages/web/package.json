  },
  "devDependencies": {
    "@effect/platform-node": "^0.107.0",
    "@solidjs/testing-library": "^0.8.10",
    "@types/node": "^22.10.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.9.3",
