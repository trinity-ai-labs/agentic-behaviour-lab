{
  "name": "@abl/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Local HTTP layer for the Agentic Behaviour Lab: typed REST API over @abl/engine plus static hosting for the dashboard.",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "default": "./dist/api.js"
    }
  },
  "bin": {
    "abl-serve": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json",
    "dev": "tsx --watch src/main.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@abl/engine": "workspace:*",
    "@effect/platform": "^0.96.2",
    "@effect/platform-node": "^0.107.0",
    "effect": "^3.21.4"
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7"
  }
}
